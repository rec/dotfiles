#!/usr/bin/env python3

import re
import sys
from itertools import chain

PARTS = '## TODO', '## DONE'


def main(file_path='TASKS.md'):
    with open(file_path) as fp:
        lines = list(fp)
    before, todo, done, index = [], [], [], 0
    for line in lines:
        index += index < 2 and line.strip() in PARTS
        (before, todo, done)[index].append(line)

    assert todo[0].startswith(PARTS[0])
    assert done[0].startswith(PARTS[1])

    before_task, task, after_task, index = [], [], [], 0
    for i, line in enumerate(todo):
        index += index < 2 and line.startswith('##') and line.strip() not in PARTS
        (before_task, task, after_task)[index].append(line)

    if not any(t.strip() for t in task):
        exit('ERROR: No tasks found')
    parts = before, before_task, after_task, done, [task.pop()], task
    with open(file_path, 'w') as fp:
        fp.writelines(i for p in parts for i in p)
    print(*task)

if __name__ == "__main__":
    main(*sys.argv[1:])
