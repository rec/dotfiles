#!/usr/bin/env python3

"""
* Split task file on lines that start with three or more dashes
* Remove empty ones
* Pop the first
* Print it without ---
* Save the popped thing in a different file.

"""

import re
import sys
# from itertools import chain, pairwise
from pathlib import Path
import sys


def main():
    name = Path('.').absolute().name
    root = Path('tasks')
    task_file = (root / name).with_suffix('.md')
    done_file = root / 'done.md'

    def is_sep(s):
        return s.startswith('---')

    cuts: list[list[str]] = [[]]
    for line in task_file.open():
        cuts[-1].append(line)
        if is_sep(line):
            cuts.append([])

    while cuts:
        task = cuts.pop(0)
        if any(t.strip() and not is_sep(t) for t in task):
            break
    else:
        sys.exit('No tasks found')

    def skip_empty(it):
        found = False
        for i in it:
            if found := found or not i.strip():
                yield i

    print(*task)
    with task_file.open('w') as fp:
        fp.writelines(skip_empty(i for c in cuts for i in c))
    with done_file.open('a') as fp:
        fp.write('---\n\n')
        fp.writelines(skip_empty(task))



if __name__ == "__main__":
    main()
